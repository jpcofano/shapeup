{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./.tsc-out/tsconfig.node.tsbuildinfo",
    "outDir": "./.tsc-out/node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}
